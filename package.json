{
  "name": "GeneracionDocumentacion",
  "type": "module",
  "version": "1.0.0",
  "main": "electron/main.js",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test": "vitest",
    "electron:dev": "concurrently \"npm run dev\" \"cross-env NODE_ENV=development electron .\"",
    "electron:build": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.solay.docgen",
    "productName": "GeneracionDocumentacion",
    "directories": {
      "output": "dist"
    },
    "npmRebuild": false,
    "files": [
      ".output/**/*",
      "electron/**/*",
      "public/**/*",
      "package.json",
      "server/utils/automation/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/logo-solay.png"
    }
  },
  "dependencies": {
    "@nuxt/content": "^3.11.0",
    "@nuxt/devtools": "^3.1.1",
    "@nuxt/image": "^2.0.0",
    "@nuxt/ui": "^4.4.0",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@pinia/nuxt": "^0.11.3",
    "@vueuse/core": "^14.2.0",
    "html2pdf.js": "^0.14.0",
    "jspdf": "^4.1.0",
    "nuxt": "^4.3.0",
    "pdf-lib": "^1.17.1",
    "pg": "^8.18.0",
    "pinia": "^3.0.4",
    "playwright": "^1.58.2",
    "vue": "^3.5.27",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/test-utils": "^2.4.6",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "jsdom": "^28.0.0",
    "vitest": "^4.0.18"
  },
  "resolutions": {
    "rollup-plugin-visualizer": "6.0.5"
  }
}
